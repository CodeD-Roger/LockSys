# Copy this file to .env and fill in the values
# Run `make setup` to auto-generate secrets

# JWT signing secret (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# SQLCipher database encryption key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
DB_KEY=

# Optional: override default paths
DB_PATH=/app/data/vaultix.db
ENVIRONMENT=production
